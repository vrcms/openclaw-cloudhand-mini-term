{
  "name": "openclaw-cloudhand-mini-term",
  "version": "1.0.0",
  "description": "CloudHand Mini-Term — 本地终端管理应用，远程 AI 智能体通过 WebSocket 操控本地 PTY",
  "main": "server.js",
  "scripts": {
    "build": "esbuild src-frontend/app.js --bundle --outfile=public/js/bundle.js --format=iife",
    "predev": "npm run build",
    "dev": "node server.js",
    "prestart": "npm run build",
    "start": "node server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "node-pty": "^1.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "esbuild": "^0.20.0"
  }
}
